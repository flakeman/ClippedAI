# HuggingFace API Token for speaker diarization
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Groq API Key for viral title generation
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# YouTube Shorts Duration Settings (in seconds)
MIN_CLIP_DURATION=45  # Minimum duration in seconds for YouTube Shorts
MAX_CLIP_DURATION=120  # Maximum duration in seconds for YouTube Shorts

# Transcription Model Settings
TRANSCRIPTION_BACKEND=clipsai  # clipsai | faster_whisper
TRANSCRIPTION_MODEL=medium  # Options: tiny, base, small, medium, large-v1, large-v2
TRANSCRIPTION_LANGUAGE_MODE=auto  # auto | forced
FORCED_LANGUAGE=en  # Supported forced languages: en, fr, de, es, it, ja, zh, nl, uk, pt

# Aspect Ratio for YouTube Shorts (width:height)
ASPECT_RATIO_WIDTH=9
ASPECT_RATIO_HEIGHT=16

# Resize strategy: auto | ai | ffmpeg | local_ai
# auto: ai -> local_ai -> ffmpeg fallback
RESIZE_MODE=auto

# Optional runtime overrides
MAX_CLIPS_OVERRIDE=0
QUIET_MODE=true
SHOW_TITLE_PROMPT=false
NLTK_AUTO_DOWNLOAD=false
ENABLE_TEXT_POSTPROCESS=true
NORMALIZE_PUNCTUATION=true
CLEAN_REPEATS=true
LLM_TEXT_CORRECTION=false
SUBTITLE_STYLE_MODE=auto  # auto | manual
SUBTITLE_STYLE_PRESET=bold_clean  # bold_clean | dramatic | minimal | newsflash

# Optional explicit ffmpeg paths (recommended on Windows if ffmpeg is not in PATH)
# FFMPEG_EXE=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_EXE=C:\ffmpeg\bin\ffprobe.exe
